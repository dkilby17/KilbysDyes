generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id               String           @id @default(cuid())
  name             String
  type             String
  description      String
  price            Float
  patternName      String
  colorFamily      String
  colorsUsed       String
  isNewDrop        Boolean          @default(false)
  careInstructions String
  status           String           @default("Active")
  createdAt        DateTime         @default(now())
  images           ProductImage[]
  variants         ProductVariant[]
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  isFront   Boolean @default(false)
  altText   String
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id        String  @id @default(cuid())
  size      String
  quantity  Int     @default(0)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  email           String
  firstName       String
  lastName        String
  address         String
  apartment       String?
  city            String
  state           String
  zip             String
  status          String      @default("Pending")
  subtotal        Float
  shippingCost    Float       @default(8.50)
  total           Float
  createdAt       DateTime    @default(now())
  items           OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  productId String
  name      String
  size      String
  quantity      Int
  price         Float
  isCustom      Boolean @default(false)
  customDetails String?
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
}
