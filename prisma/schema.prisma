generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id               String           @id @default(cuid())
  name             String
  type             String
  description      String
  price            Float
  patternName      String
  colorFamily      String
  colorsUsed       String
  isNewDrop        Boolean          @default(false)
  careInstructions String
  status           String           @default("Active")
  createdAt        DateTime         @default(now())
  images           ProductImage[]
  variants         ProductVariant[]
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  isFront   Boolean @default(false)
  altText   String
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id        String  @id @default(cuid())
  size      String
  quantity  Int     @default(0)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}
